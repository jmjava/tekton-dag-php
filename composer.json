{
  "name": "jmjava/tekton-dag-php",
  "description": "Sample PHP app for Tekton DAG",
  "type": "project",
  "require": {
    "php": ">=8.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "guzzlehttp/guzzle": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "TektonDag\\Baggage\\": "src/Baggage/"
    },
    "files": ["src/bootstrap.php"]
  },
  "autoload-dev": {
    "psr-4": {
      "TektonDag\\Tests\\": "tests/"
    }
  }
}
